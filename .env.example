# 本番(VM)用 .env のテンプレート。これをコピーして .env を作り、値を埋める:
#   cp .env.example .env && nano .env
# ※ .env は Git に上げません(.gitignore 済み)。

# 許可リスト: ログインを許可する Gmail をカンマ区切り
ALLOWLIST=

# Google OAuth (クライアントID/シークレット)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT=https://a1-takeoff.duckdns.org/auth/callback

# セッション署名用ランダム文字列(setup.sh が自動生成して入れます)
SESSION_SECRET=

# クラウド(rclone)モード: リモート名。サービスアカウントの rclone リモートを "gdrive:" で作成
RCLONE_REMOTE=gdrive:
RCLONE_CONF=/home/USER/.config/rclone/rclone.conf

# ローカルfsモード時のみ使用(クラウドでは無視される)
BASE_DIR=I:/マイドライブ/A1現場情報

PORT=5050
